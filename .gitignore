# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# local dev data stores — recreated by predev / on demand; prod uses Vercel Blob.
# (Tracking the registry churned git every dev run and risked test claims in history.)
/data/*-registry.json
/data/tickets.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# build artifacts
*.zip
*.tar

# dev-only merge-authorization audit log (like the other data stores)
/data/merges.json

# operator node-link config (holds tokens!) — never tracked; prod uses Blob
/data/nodes.json

# decisions board — recorded rulings only (the seeds are committed); prod uses Blob
/data/decisions.json

# artist registry dev stores (roster / name requests / watches) — never tracked; prod uses Blob
/data/artists.json
/data/artist-requests.json
/data/artist-watches.json

# briefs library — INTERNAL strategy, NEVER committed to this PUBLIC repo. Brief
# content lives only in the dual-driver store: gitignored local data (dev) /
# Vercel Blob (prod), pulled from the repos. Reviews too. Both tiers: the
# personal (private repo) store AND the shared (public repo) store — neither
# tier's content is ever tracked by this public repo.
/data/briefs/
/data/brief-reviews.json
/data/briefs-shared/
/data/brief-reviews-shared.json

# store — catalog is dual-driver (dev file / prod blob); orders are PII and
# live only in the private driver (dev files / prod KV), never in git.
/data/store-catalog.json
/data/store-orders/

# store product shots, dev driver (prod uses public Blob) — never tracked
/public/store-media/
