# ── Space configuration ──────────────────────────────────────────────
# One deployment = one space. Fork this repo, change these two values,
# and you have a registration site for your own Spaces-protocol space.

# The space this site registers names under (tag = name@<space>)
NEXT_PUBLIC_SPACE_NAME=frens

# The domain this site is served from. NIP-05 identities are
# name@<this domain>, so it MUST be the domain that serves
# /.well-known/nostr.json (i.e. this app's production domain).
NEXT_PUBLIC_NIP05_DOMAIN=frens.earth

# ── Storage (production only) ────────────────────────────────────────
# Vercel Blob store token — local dev uses a JSON file instead and
# works with no configuration at all.
#   npx vercel blob create-store my-registry --access public --yes
BLOB_READ_WRITE_TOKEN=

# ── Fren sessions ────────────────────────────────────────────────────
# HMAC secret for the pa-fren login/session cookie. REQUIRED in production:
# without it, returning sign-in, tag release, and /admin all 500.
# Any long random string:  openssl rand -hex 32
SEAT_SECRET=

# ── Operator console (/a admin) ──────────────────────────────────────
# Comma-separated npubs allowed into the /a admin areas. Leave empty to
# disable them entirely.
#   OPERATOR_NPUBS=npub1abc...,npub1def...
OPERATOR_NPUBS=

# ── Spaces node (on-chain anchoring — optional) ──────────────────────
# This deployment's own `spaced` JSON-RPC endpoint. Leave unset and tags
# stay `queued` (still fully usable on nostr). `spaced` is localhost-only
# with no built-in auth, so a remote/serverless deploy must point this at an
# authenticating proxy and set a token. See docs/spaces-anchoring.md.
#   SPACES_NODE_URL=http://127.0.0.1:7225
SPACES_NODE_URL=
SPACES_NODE_TOKEN=

# ── SCAR merge queue (optional) ──────────────────────────────────────
# Fine-grained GitHub PAT so the /a/scar AUTHORIZE button can list PRs and
# execute sha-guarded merges. Generate at github.com → Settings → Developer
# settings → Fine-grained tokens: resource owner = your org, repository
# access = this repo only, permissions = Contents (read/write) +
# Pull requests (read/write). Without it, signed authorizations are still
# recorded — merges just happen on GitHub.
GITHUB_TOKEN=
# The repo the queue watches (owner/name). Defaults to PacsArcade/frens.earth.
GITHUB_REPO=

# ── MUD node (P.O.K.E. — optional) ───────────────────────────────────
# This deployment's own MUD node (knowledge-engine, admin API on :4001).
# Tickets work without it; the game surface stays dark until set.
# MUD_ADMIN_TOKEN is the node's X-POKE-Admin-Token. See docs/spaces-anchoring.md.
#   MUD_NODE_URL=http://127.0.0.1:4001
MUD_NODE_URL=
MUD_ADMIN_TOKEN=

# ── Optional ─────────────────────────────────────────────────────────
# Force the Vercel Blob driver in local dev (needs BLOB_READ_WRITE_TOKEN too).
# On Vercel the blob driver turns on automatically; unset locally = file driver.
#   REGISTRY_DRIVER=blob
REGISTRY_DRIVER=

# Knowledge-engine node backing the profile's P.O.K.E. card (arcade stats).
# Optional — the card degrades gracefully when unset.
#   POKE_NODE_URL=https://node.example
#   NEXT_PUBLIC_POKE_NODE_URL=https://node.example
POKE_NODE_URL=
NEXT_PUBLIC_POKE_NODE_URL=
